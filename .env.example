# =============================================================================
# Adaptive AI for Cyber Threat Detection — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
APP_NAME=AdaptiveAICyberThreat
APP_VERSION=1.0.0
APP_ENV=development
# Options: development | staging | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars

# ---------------------------------------------------------------------------
# API SERVER
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/threat_db.sqlite
# For production PostgreSQL (Supabase free tier):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# MODEL PATHS
# ---------------------------------------------------------------------------
MODELS_DIR=data/models
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# ---------------------------------------------------------------------------
# HUGGING FACE (Free — no token needed for public models)
# ---------------------------------------------------------------------------
HF_MODEL_PHISHING=distilbert-base-uncased
HF_MODEL_CACHE_DIR=data/models/hf_cache

# ---------------------------------------------------------------------------
# STREAMLIT DASHBOARD
# ---------------------------------------------------------------------------
DASHBOARD_PORT=8501
DASHBOARD_THEME=dark

# ---------------------------------------------------------------------------
# REPORT GENERATION
# ---------------------------------------------------------------------------
REPORTS_DIR=data/reports
REPORTS_MAX_ENTRIES=1000

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
