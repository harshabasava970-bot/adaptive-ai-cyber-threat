# =============================================================================
# .gitignore — Adaptive AI for Cyber Threat Detection
# =============================================================================

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# PyTorch / ML model artifacts (large files — use HuggingFace Hub instead)
data/models/*.pt
data/models/*.pth
data/models/*.pkl
data/models/*.joblib
data/models/hf_cache/

# But keep the directory structure
!data/models/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
logs/
*.log

# Database (SQLite local file)
*.sqlite
*.sqlite3
*.db

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Reports (generated — don't commit)
data/reports/

# Streamlit cache
.streamlit/

# Docker
docker/secrets/
